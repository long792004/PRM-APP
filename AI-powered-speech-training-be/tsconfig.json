{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "types": [
      "node"
    ],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist",
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "src/**/*",
    "prisma/**/*",
    "*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}